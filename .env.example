# Polymarket API Credentials
# 1. Add your private key below
# 2. Run: npm run setup
# 3. The setup script will generate and add API credentials automatically
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Database Connection
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://username:password@host.render.com:5432/dbname

# Telegram Notifications (Optional)
# Get your bot token from @BotFather on Telegram
# Get your chat ID from @userinfobot after sending /start
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Note: All other configuration (execution mode, polling interval, logging, etc.)
# should be set in config.json, not here.
