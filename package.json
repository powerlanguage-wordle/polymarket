{
  "name": "polymarket-copy-trader",
  "version": "1.0.0",
  "description": "Automated copy-trading bot for Polymarket that monitors and replicates trades from selected wallets",
  "main": "dist/bot.js",
  "scripts": {
    "build": "tsc",
    "build:dashboard": "cd dashboard && npm install && npm run build && cd ..",
    "start": "node dist/bot.js",
    "dev": "ts-node src/bot.ts",
    "setup": "ts-node scripts/setup-api-credentials.ts",
    "setup:telegram": "ts-node scripts/setup-telegram.ts",
    "test:telegram": "ts-node scripts/test-telegram.ts",
    "reset": "ts-node scripts/reset-paper-trading.ts",
    "status": "ts-node scripts/check-trades.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "polymarket",
    "trading",
    "bot",
    "copy-trading",
    "blockchain"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "@types/node-telegram-bot-api": "^0.64.14",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^5.7.2",
    "express": "^4.18.2",
    "lru-cache": "^10.2.0",
    "node-telegram-bot-api": "^0.67.0",
    "pg": "^8.11.3",
    "winston": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
